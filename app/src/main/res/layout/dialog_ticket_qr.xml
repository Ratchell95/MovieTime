<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_badge_green"
    android:backgroundTint="#FFFFFF"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvTicketPelicula"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pelicula"
        android:textSize="22sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvTicketInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SALA 00  •  Butacas: --"
        android:textSize="16sp"
        android:textColor="#444444"
        android:textStyle="bold"/>

    <ImageView
        android:id="@+id/ivTicketQR"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Muestra este código al empleado de control\npara ingresar a tu función."
        android:textSize="13sp"
        android:textColor="#888888"
        android:gravity="center"/>
</LinearLayout>