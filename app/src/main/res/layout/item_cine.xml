<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- IMAGEN DE LA SEDE -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp">

            <ImageView
                android:id="@+id/ivImagenCine"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Imagen del cine" />

            <!-- Overlay oscuro sobre la imagen -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#66000033" />

        </FrameLayout>

        <!-- CONTENIDO INFERIOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Nombre de la sede -->
            <TextView
                android:id="@+id/tvNombreCine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MOVIE TIME PREMIUM BASADRE"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Dirección -->
            <TextView
                android:id="@+id/tvDireccionCine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="CAL. LAS PALMERAS URB. ORRANTIA 0343"
                android:textColor="#666666"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp" />

            <!-- Formato (chip) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvFormato"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2D"
                    android:textColor="#444444"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#E8E8E8"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            <!-- Botón Ver en mapa -->
            <Button
                android:id="@+id/btnVerMapa"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:text="Ver en mapa"
                android:textAllCaps="false"
                android:textColor="#E53935"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#E53935"
                app:strokeWidth="1.5dp"
                app:cornerRadius="6dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
