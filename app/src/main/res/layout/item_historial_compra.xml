<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:elevation="2dp">

    <!-- Fila 1: título + estado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvHistTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Película"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvHistEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Completada"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Fila 2: fecha función -->
    <TextView
        android:id="@+id/tvHistFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mié 18 Mar · 03:00 PM"
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginBottom="2dp" />

    <!-- Fila 3: sala + butaca -->
    <TextView
        android:id="@+id/tvHistButaca"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Butaca K5 · Sala 01"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <!-- Fila 4: total + método -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvHistMetodo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Yape · Boleta"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvHistTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S/ 36.00"
            android:textColor="#003087"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Indicador "Ver detalle →" -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver detalle →"
        android:textColor="#003087"
        android:textSize="12sp"
        android:gravity="end"
        android:layout_marginTop="6dp" />

</LinearLayout>
