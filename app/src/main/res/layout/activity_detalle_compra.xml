<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:fitsSystemWindows="true">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_secundario"
        android:layout_width="match_parent"
        android:layout_height="56dp" />

    <!-- SCROLL PRINCIPAL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ESTADO DE COMPRA -->
            <TextView
                android:id="@+id/tvEstadoCompra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="✓ Compra exitosa"
                android:textColor="#4CAF50"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvFechaDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="15 Mar 2025 · 08:30 PM"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginBottom="24dp" />

            <!-- ─── TARJETA QR (solo para entradas) ─────────────── -->
            <LinearLayout
                android:id="@+id/cardQR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="20dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎫 TU ENTRADA"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <!-- QR generado por ZXing -->
                <ImageView
                    android:id="@+id/ivQR"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:contentDescription="Código QR de entrada"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvCodigoQR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XXXXXXXXXXXX"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <!-- Badge estado ingreso -->
                <TextView
                    android:id="@+id/tvEstadoIngreso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Pendiente de ingreso"
                    android:textSize="12sp"
                    android:textColor="#FFA726"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A2A"
                    android:layout_marginBottom="16dp" />

                <!-- Detalle película/función -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPelicula"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Título de la película"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Sala"
                            android:textColor="#888888"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvSala"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sala 3 XD"
                            android:textColor="#CCCCCC"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Butaca"
                            android:textColor="#888888"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvButaca"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="F-12"
                            android:textColor="#CCCCCC"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Función"
                            android:textColor="#888888"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvFuncion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sáb 15 Mar · 08:30 PM"
                            android:textColor="#CCCCCC"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ─── TARJETA CONFITERÍA ──────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardConfiteria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍿 CONFITERÍA"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/containerProductos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- ─── TARJETA RESUMEN PAGO ──────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳 RESUMEN DE PAGO"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Subtotal"
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S/ 40.00"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutDescuento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Descuento"
                        android:textColor="#4CAF50"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvDescuento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-S/ 5.00"
                        android:textColor="#4CAF50"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A2A"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total pagado"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S/ 45.00"
                        android:textColor="#4FC3F7"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMetodoDetalle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Yape"
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvComprobanteDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Boleta"
                        android:textColor="#888888"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>


            <TextView
                android:id="@+id/tvNotaQR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Presenta este QR en la entrada del cine.\nEl código contiene toda la información de tu entrada."
                android:textColor="#555555"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>