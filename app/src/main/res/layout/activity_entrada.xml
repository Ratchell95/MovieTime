<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/toolbar"
            layout="@layout/toolbar_secundario"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- PASOS -->
        <LinearLayout
            android:id="@+id/layoutPasos"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪑" android:textSize="16sp"/>
            </LinearLayout>
            <View android:layout_width="40dp" android:layout_height="2dp" android:background="#003087" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#003087" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟" android:textSize="16sp"/>
            </LinearLayout>
            <View android:layout_width="40dp" android:layout_height="2dp" android:background="#DDDDDD" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍿" android:textSize="16sp"/>
            </LinearLayout>
            <View android:layout_width="40dp" android:layout_height="2dp" android:background="#DDDDDD" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💳" android:textSize="16sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- INFO PELÍCULA -->
        <LinearLayout
            android:id="@+id/layoutInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/layoutPasos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTituloEntrada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvDuracionEntrada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#666666"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvSedeEntrada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#003087"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅 " android:textSize="11sp"/>
                    <TextView android:id="@+id/tvFechaEntrada" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕐 " android:textSize="11sp"/>
                    <TextView android:id="@+id/tvHoraEntrada" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  🎬 " android:textSize="11sp"/>
                    <TextView android:id="@+id/tvSalaEntrada" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- SCROLL CONTENIDO -->
        <ScrollView
            android:id="@+id/scrollEntrada"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#F2F2F2"
            app:layout_constraintTop_toBottomOf="@id/layoutInfo"
            app:layout_constraintBottom_toTopOf="@id/layoutFooter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Código promo Yape -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aplicar Promo Yape"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_yape"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Yape"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#CCCCCC"
                        app:boxCornerRadiusTopStart="4dp"
                        app:boxCornerRadiusTopEnd="4dp"
                        app:boxCornerRadiusBottomStart="4dp"
                        app:boxCornerRadiusBottomEnd="4dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCodigoPromo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Código"
                            android:textSize="14sp"
                            android:textColorHint="#AAAAAA"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnValidarPromo"
                        android:layout_width="90dp"
                        android:layout_height="44dp"
                        android:backgroundTint="#7B2D8B"
                        android:text="Validar"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        app:cornerRadius="6dp"/>
                </LinearLayout>

                <!-- Título sección entradas -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Entradas"
                    android:textColor="#1A1A2E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- ADULTO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ADULTO S/18.00"
                        android:textColor="#333333"
                        android:textSize="13sp"/>

                    <Button
                        android:id="@+id/btnMenosAdulto"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="-"
                        android:textSize="18sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="#FFFFFF"
                        android:padding="0dp"
                        app:cornerRadius="6dp"/>

                    <TextView
                        android:id="@+id/tvCantAdulto"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnMasAdulto"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="#FFFFFF"
                        android:padding="0dp"
                        app:cornerRadius="6dp"/>

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="= S/0.00"
                        android:id="@+id/tvSubAdulto"
                        android:gravity="end"
                        android:textColor="#333333"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- INFANTIL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="INFANTIL DE 2-8 S/15.00"
                        android:textColor="#333333"
                        android:textSize="13sp"/>

                    <Button
                        android:id="@+id/btnMenosInfantil"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="-"
                        android:textSize="18sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="#FFFFFF"
                        android:padding="0dp"
                        app:cornerRadius="6dp"/>

                    <TextView
                        android:id="@+id/tvCantInfantil"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnMasInfantil"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="#FFFFFF"
                        android:padding="0dp"
                        app:cornerRadius="6dp"/>

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:id="@+id/tvSubInfantil"
                        android:text="= S/0.00"
                        android:gravity="end"
                        android:textColor="#333333"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- ADULTO MAYOR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AD.MAYOR+60 S/15.00"
                        android:textColor="#333333"
                        android:textSize="13sp"/>

                    <Button
                        android:id="@+id/btnMenosMayor"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="-"
                        android:textSize="18sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="#FFFFFF"
                        android:padding="0dp"
                        app:cornerRadius="6dp"/>

                    <TextView
                        android:id="@+id/tvCantMayor"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnMasMayor"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="#FFFFFF"
                        android:padding="0dp"
                        app:cornerRadius="6dp"/>

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:id="@+id/tvSubMayor"
                        android:text="= S/0.00"
                        android:gravity="end"
                        android:textColor="#333333"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- FOOTER FIJO -->
        <LinearLayout
            android:id="@+id/layoutFooter"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total: S/ 0.00"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnSiguiente"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:backgroundTint="#AAAAAA"
                android:text="Siguiente ›"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"
                app:cornerRadius="22dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>