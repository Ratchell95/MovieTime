<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- INFO PELÍCULA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/ivPoster"
                android:layout_width="80dp"
                android:layout_height="110dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Poster" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TÍTULO PELÍCULA"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDuracion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="1 hr 55 min | APT"
                    android:textColor="#777777"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="▶  Ver trailer"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- SINOPSIS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:background="#FFFFFF">
            <TextView
                android:id="@+id/tvSinopsis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción de la película..."
                android:textColor="#444444"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:ellipsize="end" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ver más"
                android:textColor="#E53935"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SEPARADOR -->
        <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

        <!-- SELECTOR FECHAS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">
            <LinearLayout
                android:id="@+id/layoutFechas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Hoy -->
                <LinearLayout
                    android:id="@+id/btnFecha1"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#CCCCCC">
                    <TextView android:id="@+id/tvLabel1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoy" android:textColor="#555555" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDia1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16" android:textColor="#333333" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvMes1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="marzo" android:textColor="#777777" android:textSize="11sp" />
                </LinearLayout>

                <!-- Mañana -->
                <LinearLayout
                    android:id="@+id/btnFecha2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#EEEEEE">
                    <TextView android:id="@+id/tvLabel2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mañana" android:textColor="#555555" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDia2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="17" android:textColor="#333333" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvMes2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="marzo" android:textColor="#777777" android:textSize="11sp" />
                </LinearLayout>

                <!-- Pasado -->
                <LinearLayout
                    android:id="@+id/btnFecha3"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#EEEEEE">
                    <TextView android:id="@+id/tvLabel3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="mié" android:textColor="#555555" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDia3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18" android:textColor="#333333" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvMes3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="marzo" android:textColor="#777777" android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- SEPARADOR -->
        <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

        <!-- SEDE CHORRILLOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="8dp"
            android:background="#FFFFFF"
            android:text="CHORRILLOS"
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="14dp"
            android:background="#FFFFFF">
            <LinearLayout android:id="@+id/btnHorarioChorrillos1" android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F9F9F9" android:padding="10dp" android:layout_marginEnd="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="03:00 PM" android:textColor="#333333" android:textSize="15sp" android:gravity="center" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="6dp" android:background="#FFD6D6" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟  Comprar" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/btnHorarioChorrillos2" android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F9F9F9" android:padding="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="07:30 PM" android:textColor="#333333" android:textSize="15sp" android:gravity="center" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="6dp" android:background="#FFD6D6" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟  Comprar" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

        <!-- SEDE MOVIETIME IQUITOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="8dp"
            android:background="#FFFFFF"
            android:text="MOVIETIME IQUITOS"
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="14dp"
            android:background="#FFFFFF">
            <LinearLayout android:id="@+id/btnHorarioIquitos1" android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F9F9F9" android:padding="10dp" android:layout_marginEnd="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="03:00 PM" android:textColor="#333333" android:textSize="15sp" android:gravity="center" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="6dp" android:background="#FFD6D6" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟  Comprar" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/btnHorarioIquitos2" android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F9F9F9" android:padding="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10:00 PM" android:textColor="#333333" android:textSize="15sp" android:gravity="center" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="6dp" android:background="#FFD6D6" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟  Comprar" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

        <!-- SEDE VES1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="8dp"
            android:background="#FFFFFF"
            android:text="VES1"
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="14dp"
            android:background="#FFFFFF">
            <LinearLayout android:id="@+id/btnHorarioVes1" android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F9F9F9" android:padding="10dp" android:layout_marginEnd="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="04:00 PM" android:textColor="#333333" android:textSize="15sp" android:gravity="center" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="6dp" android:background="#FFD6D6" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟  Comprar" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Espacio al final para el bottom nav -->
        <View android:layout_width="match_parent" android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>