<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HEADER AZUL -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="#003087"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btnAtras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Atrás"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tvCronometro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ 10:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- INFO PELÍCULA -->
        <LinearLayout
            android:id="@+id/layoutInfoPelicula"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivPosterAsiento"
                android:layout_width="72dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Poster" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/tvTituloAsiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TÍTULO PELÍCULA"
                    android:textColor="#111111"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDuracionAsiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="1 hr 54 min | +14"
                    android:textColor="#777777"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvSedeAsiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="MOVIETIME IQUITOS"
                    android:textColor="#003087"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅 " android:textSize="11sp" />
                    <TextView android:id="@+id/tvFechaAsiento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoy lun. 16 mar, 2026" android:textColor="#555555" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏰ " android:textSize="11sp" />
                    <TextView android:id="@+id/tvHoraAsiento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:00 PM" android:textColor="#555555" android:textSize="11sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  🎬 " android:textSize="11sp" />
                    <TextView android:id="@+id/tvSalaAsiento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SALA: 05" android:textColor="#555555" android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- PASOS -->
        <LinearLayout
            android:id="@+id/layoutPasos"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/layoutInfoPelicula"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Paso 1: Asientos (activo) -->
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#003087" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪑" android:textSize="16sp" />
            </LinearLayout>
            <View android:layout_width="50dp" android:layout_height="2dp" android:background="#CCCCCC" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
            <!-- Paso 2 -->
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟" android:textSize="16sp" />
            </LinearLayout>
            <View android:layout_width="50dp" android:layout_height="2dp" android:background="#CCCCCC" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
            <!-- Paso 3 -->
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍿" android:textSize="16sp" />
            </LinearLayout>
            <View android:layout_width="50dp" android:layout_height="2dp" android:background="#CCCCCC" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
            <!-- Paso 4 -->
            <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💳" android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- PANTALLA -->
        <LinearLayout
            android:id="@+id/layoutPantalla"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/layoutPasos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:background="#003087" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PANTALLA"
                android:textColor="#003087"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="3dp"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- GRID ASIENTOS -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAsientos"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#F0F0F0"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/layoutPantalla"
            app:layout_constraintBottom_toTopOf="@id/layoutLeyenda"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- LEYENDA -->
        <LinearLayout
            android:id="@+id/layoutLeyenda"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#FFFFFF"
            app:layout_constraintBottom_toTopOf="@id/layoutInferior"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:layout_width="14dp" android:layout_height="14dp" android:background="#4CAF50" android:layout_marginEnd="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seleccionada" android:textColor="#444444" android:textSize="11sp" android:layout_marginEnd="14dp" />

            <View android:layout_width="14dp" android:layout_height="14dp" android:background="#BBBBBB" android:layout_marginEnd="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ocupada" android:textColor="#444444" android:textSize="11sp" android:layout_marginEnd="14dp" />

            <View android:layout_width="14dp" android:layout_height="14dp" android:background="#EEEEEE" android:layout_marginEnd="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Libre" android:textColor="#444444" android:textSize="11sp" />
        </LinearLayout>

        <!-- PANEL INFERIOR -->
        <LinearLayout
            android:id="@+id/layoutInferior"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvSeleccionadas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Butacas: "
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnContinuar"
                android:layout_width="130dp"
                android:layout_height="44dp"
                android:backgroundTint="#333333"
                android:text="Siguiente ›"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"
                app:cornerRadius="22dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>