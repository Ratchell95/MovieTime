<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F8F9FF"
    android:padding="10dp"
    android:layout_marginBottom="6dp">

    <!-- Película + formato -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvFilaPelicula"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nombre película · 2D"
            android:textColor="#222222"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFilaEstadoIngreso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendiente"
            android:textSize="11sp"
            android:textColor="#FFA726" />
    </LinearLayout>

    <!-- Sala y butaca -->
    <TextView
        android:id="@+id/tvFilaSalaButaca"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sala 3 XD — Butaca F-12"
        android:textColor="#555555"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <!-- Fecha función -->
    <TextView
        android:id="@+id/tvFilaFuncion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sáb 15 Mar · 08:30 PM"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

</LinearLayout>
