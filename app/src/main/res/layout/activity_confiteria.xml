<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">


    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2F2F2">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/header"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:background="@color/toolbar_bg"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="12dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_menu"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF"
                    android:contentDescription="Menú" />

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_icono2"
                    android:scaleType="fitStart"
                    android:contentDescription="Logo" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chocolatería"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <LinearLayout
                android:id="@+id/layoutPasos"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                app:layout_constraintTop_toBottomOf="@id/header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪑" android:textSize="16sp" />
                </LinearLayout>
                <View android:layout_width="50dp" android:layout_height="2dp" android:background="#003087" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
                <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟" android:textSize="16sp" />
                </LinearLayout>
                <View android:layout_width="50dp" android:layout_height="2dp" android:background="#003087" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
                <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#003087" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍿" android:textSize="16sp" />
                </LinearLayout>
                <View android:layout_width="50dp" android:layout_height="2dp" android:background="#CCCCCC" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
                <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="#DDDDDD" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💳" android:textSize="16sp" />
                </LinearLayout>

            </LinearLayout>


            <HorizontalScrollView
                android:id="@+id/scrollCategorias"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                app:layout_constraintTop_toBottomOf="@id/layoutPasos"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/layoutCategorias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/catPopcorn"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:gravity="center"
                        android:text="POP CORN"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#222222"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/catCombos"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:gravity="center"
                        android:text="COMBOS"
                        android:textSize="12sp"
                        android:textColor="#444444"
                        android:background="#EEEEEE"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/catSandwich"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:gravity="center"
                        android:text="SANDWICH Y EMBUTIDOS"
                        android:textSize="12sp"
                        android:textColor="#444444"
                        android:background="#EEEEEE"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- GRID PRODUCTOS (sin cambios) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProductos"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:padding="8dp"
                android:clipToPadding="false"
                android:background="#F2F2F2"
                app:layout_constraintTop_toBottomOf="@id/scrollCategorias"
                app:layout_constraintBottom_toTopOf="@id/layoutFooter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <LinearLayout
                android:id="@+id/layoutFooter"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total: S/ 0.00"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnSiguiente"
                    android:layout_width="140dp"
                    android:layout_height="44dp"
                    android:backgroundTint="#555555"
                    android:text="Siguiente ›"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="22dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>


    <include
        layout="@layout/nav_drawer"
        android:id="@+id/navDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>