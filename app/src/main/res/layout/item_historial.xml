<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Título película -->
        <TextView
            android:id="@+id/tvHistTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1A1A2E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Sede -->
        <TextView
            android:id="@+id/tvHistSede"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#003087"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Fecha y hora -->
        <TextView
            android:id="@+id/tvHistFechaHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#555555"
            android:textSize="13sp"
            android:layout_marginBottom="2dp" />

        <!-- Butacas -->
        <TextView
            android:id="@+id/tvHistButacas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#555555"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp" />

        <!-- Fila total + método -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvHistTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#1A1A2E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistMetodo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#777777"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Código QR -->
        <TextView
            android:id="@+id/tvHistCodigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />

        <!-- Fecha de compra -->
        <TextView
            android:id="@+id/tvHistFechaCompra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#BBBBBB"
            android:textSize="11sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
