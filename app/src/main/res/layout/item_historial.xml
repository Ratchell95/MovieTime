<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: Título película + Total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvHistTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Título de película"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/tvHistTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#003087" />
        </LinearLayout>

        <!-- Fila 2: Sede -->
        <TextView
            android:id="@+id/tvHistSede"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sede"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <!-- Fila 3: Fecha y hora -->
        <TextView
            android:id="@+id/tvHistFechaHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha  Hora"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <!-- Fila 4: Butacas -->
        <TextView
            android:id="@+id/tvHistButacas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Butacas: —"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="6dp" />

        <!-- Fila 5: Método pago + Código QR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvHistMetodo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Yape · Boleta"
                android:textSize="12sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvHistCodigo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cód: XXXXXX"
                android:textSize="11sp"
                android:textColor="#888888"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Fila 6: Fecha de compra -->
        <TextView
            android:id="@+id/tvHistFechaCompra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comprado el —"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>